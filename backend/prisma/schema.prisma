generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TECHNICIAN
  CHEFE_SETOR
  USER
}

enum Prefixo {
  GOVERNO
  TERCEIRIZADO
  ESTAGIARIO
}

enum TicketStatus {
  OPEN
  VIEWED
  EN_ROUTE
  IN_SERVICE
  COMPLETED
}

enum ApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum OsStatus {
  ABERTA
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

enum OsTipo {
  VISITA_TECNICA
  TROCA_EQUIPAMENTO
  ENTREGA
  MANUTENCAO_REDE
  MANUTENCAO_CAMERA
  RECOLHIMENTO_EQUIPAMENTO
  ACAO
  OUTRO
}

enum InventoryStatus {
  ATIVO
  INATIVO
}

enum MovementType {
  ENTRADA
  SAIDA
  AJUSTE
}

enum Nucleo {
  NMT
  NIR
}

enum ChecklistStatus {
  PENDENTE
  APROVADO
  REJEITADO
}

enum UnitStatus {
  DISPONIVEL
  EM_USO
  INATIVO
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Department {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  tickets         Ticket[]
  users           User[]           @relation("UserDepartment")
  ticketApprovals TicketApproval[]
}

model Unit {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  technicians User[]
  tickets     Ticket[]
  workOrders  WorkOrder[]
}

model User {
  id                 Int        @id @default(autoincrement())
  cpf                String     @unique
  name               String
  passwordHash       String
  role               Role       @default(USER)
  active             Boolean    @default(true)
  unitId             Int?
  unit               Unit?      @relation(fields: [unitId], references: [id])
  departmentId       Int?
  department         Department? @relation("UserDepartment", fields: [departmentId], references: [id])
  matricula          String?
  prefixo            Prefixo?
  email              String?
  telefone           String?
  isChefe            Boolean    @default(false)
  mustChangePassword Boolean    @default(false)
  createdAt          DateTime   @default(now())
  assignedTickets    Ticket[]   @relation("AssignedTechnician")
  openedTickets      Ticket[]   @relation("TicketOpener")
  history            TicketHistory[]
  comments           TicketComment[]
  resolvedRequests   PasswordResetRequest[] @relation("ResolvedRequests")
  createdWorkOrders  WorkOrder[]      @relation("OsCreator")
  osTecnico          OsTecnico[]
  osHistory          OsHistory[]
  ticketApprovals    TicketApproval[] @relation("ApprovalChef")
  inventoryItems     InventoryItem[]  @relation("InventoryCreator")
  inventoryUnits     InventoryUnit[]  @relation("InventoryUnitCreator")
  inventoryMovements InventoryMovement[] @relation("MovementCreator")
  nucleoResponsavel  Nucleo?
  checklistsCreated  InventoryChecklist[] @relation("ChecklistCreator")
  checklistsApproved InventoryChecklist[] @relation("ChecklistApprover")

  @@index([departmentId])
  @@index([role, active])
}

model PasswordResetRequest {
  id           Int       @id @default(autoincrement())
  cpf          String
  name         String
  phone        String
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
  resolvedById Int?
  resolvedBy   User?     @relation("ResolvedRequests", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([cpf])
}

model Category {
  id             Int           @id @default(autoincrement())
  code           String        @unique
  name           String
  icon           String?
  sortOrder      Int           @default(0)
  allowsFreeText Boolean       @default(false)
  n1Tips         String?       @db.Text
  slaHours       Int?
  subcategories  Subcategory[]
  tickets        Ticket[]
}

model Subcategory {
  id                 Int      @id @default(autoincrement())
  name               String
  code               String?  @unique
  sortOrder          Int      @default(0)
  slaHours              Int?
  requiresApproval      Boolean  @default(false)
  dualApproval          Boolean  @default(false)
  requiresPresential    Boolean  @default(true)
  requiresCauseSolution Boolean  @default(true)
  categoryId            Int
  category           Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tickets            Ticket[]
}

model Ticket {
  id                  Int          @id @default(autoincrement())
  ticketNumber        String       @unique
  requesterName       String
  requesterCpf        String
  department          String
  departmentId        Int?
  departmentRef       Department?  @relation(fields: [departmentId], references: [id])
  categoryId          Int
  category            Category     @relation(fields: [categoryId], references: [id])
  subcategoryId       Int?
  subcategory         Subcategory? @relation(fields: [subcategoryId], references: [id])
  freeTextDescription String?      @db.Text
  status              TicketStatus @default(OPEN)
  unitId              Int?
  unit                Unit?        @relation(fields: [unitId], references: [id])
  assignedTechId      Int?
  assignedTech        User?        @relation("AssignedTechnician", fields: [assignedTechId], references: [id])
  openedById          Int?
  openedBy            User?        @relation("TicketOpener", fields: [openedById], references: [id])
  anyDeskCode         String?
  extraData           Json?
  priority            Priority     @default(MEDIUM)
  approvalStatus      ApprovalStatus @default(NOT_REQUIRED)
  approvalNote        String?      @db.Text
  presential            Boolean      @default(true)
  requiresCauseSolution Boolean      @default(true)
  cause               String?      @db.Text
  solution            String?      @db.Text
  slaDeadline         DateTime?
  openedAt            DateTime     @default(now())
  viewedAt            DateTime?
  enRouteAt           DateTime?
  inServiceAt         DateTime?
  completedAt         DateTime?
  history             TicketHistory[]
  comments            TicketComment[]
  feedback            Feedback?
  workOrders          TicketWorkOrder[]
  approvals           TicketApproval[]

  @@index([status])
  @@index([approvalStatus])
  @@index([unitId])
  @@index([assignedTechId])
  @@index([openedById])
  @@index([openedAt])
  @@index([categoryId])
  @@index([departmentId])
}

model TicketApproval {
  id         Int        @id @default(autoincrement())
  ticketId   Int
  ticket     Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  chefDeptId Int
  chefDept   Department @relation(fields: [chefDeptId], references: [id])
  chefUserId Int?
  chefUser   User?      @relation("ApprovalChef", fields: [chefUserId], references: [id])
  status     String     @default("PENDING")
  note       String?    @db.Text
  decidedAt  DateTime?
  createdAt  DateTime   @default(now())

  @@index([ticketId])
  @@index([chefDeptId, status])
}

model TicketHistory {
  id           Int          @id @default(autoincrement())
  ticketId     Int
  ticket       Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromStatus   TicketStatus?
  toStatus     TicketStatus
  actorId      Int?
  actor        User?        @relation(fields: [actorId], references: [id])
  internalNote String?      @db.Text
  createdAt    DateTime     @default(now())

  @@index([ticketId])
}

model Feedback {
  id        Int      @id @default(autoincrement())
  ticketId  Int      @unique
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
}

model TicketComment {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@index([ticketId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int?
  actorName  String
  action     String
  targetType String
  targetId   String?
  details    String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

model ConfigFlag {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model DailyCounter {
  date        DateTime @id @db.Date
  ticketCount Int      @default(0)
  osCount     Int      @default(0)
}

model WorkOrder {
  id          Int               @id @default(autoincrement())
  osNumber    String            @unique
  tipo        OsTipo
  status      OsStatus          @default(ABERTA)
  local       String
  problema    String?           @db.Text
  materiais   String?           @db.Text
  prazo       DateTime?
  relatorio   String?           @db.Text
  unitId      Int?
  unit        Unit?             @relation(fields: [unitId], references: [id])
  createdById Int?
  createdBy   User?             @relation("OsCreator", fields: [createdById], references: [id])
  tecnicos    OsTecnico[]
  tickets     TicketWorkOrder[]
  history     OsHistory[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  startedAt   DateTime?
  concludedAt DateTime?
  cancelledAt DateTime?

  @@index([status])
  @@index([unitId])
}

model OsTecnico {
  osId    Int
  userId  Int
  os      WorkOrder @relation(fields: [osId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id])

  @@id([osId, userId])
}

model TicketWorkOrder {
  ticketId    Int
  workOrderId Int
  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@id([ticketId, workOrderId])
}

model OsHistory {
  id         Int       @id @default(autoincrement())
  osId       Int
  os         WorkOrder @relation(fields: [osId], references: [id], onDelete: Cascade)
  actorId    Int?
  actor      User?     @relation(fields: [actorId], references: [id])
  fromStatus OsStatus?
  toStatus   OsStatus
  note       String?   @db.Text
  createdAt  DateTime  @default(now())

  @@index([osId])
}

model InventoryItem {
  id          Int               @id @default(autoincrement())
  name        String
  description String?           @db.Text
  unitMeasure String            @default("un")
  category    String?
  nucleo      Nucleo?
  status      InventoryStatus   @default(ATIVO)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdById Int
  createdBy   User              @relation("InventoryCreator", fields: [createdById], references: [id])
  units       InventoryUnit[]
  movements   InventoryMovement[]

  @@index([status])
  @@index([category])
  @@index([nucleo])
}

model InventoryUnit {
  id          Int           @id @default(autoincrement())
  itemId      Int
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tombo       String?
  status      UnitStatus    @default(DISPONIVEL)
  note        String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdById Int
  createdBy   User          @relation("InventoryUnitCreator", fields: [createdById], references: [id])
  checklistItems InventoryChecklistItem[]

  @@index([itemId])
  @@index([status])
  @@index([tombo])
}

model InventoryMovement {
  id          Int           @id @default(autoincrement())
  itemId      Int
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type        MovementType
  quantity    Int
  note        String?       @db.Text
  createdAt   DateTime      @default(now())
  createdById Int
  createdBy   User          @relation("MovementCreator", fields: [createdById], references: [id])

  @@index([itemId])
  @@index([createdAt])
}

model InventoryChecklist {
  id           Int                      @id @default(autoincrement())
  title        String
  nucleo       Nucleo
  note         String?                  @db.Text
  status       ChecklistStatus          @default(PENDENTE)
  approvedById Int?
  approvedBy   User?                    @relation("ChecklistApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  rejectedNote String?                  @db.Text
  createdAt    DateTime                 @default(now())
  createdById  Int
  createdBy    User                     @relation("ChecklistCreator", fields: [createdById], references: [id])
  items        InventoryChecklistItem[]

  @@index([status])
  @@index([nucleo])
  @@index([createdAt])
}

model InventoryChecklistItem {
  id          Int                @id @default(autoincrement())
  checklistId Int
  checklist   InventoryChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  unitId      Int
  unit        InventoryUnit      @relation(fields: [unitId], references: [id])

  @@index([checklistId])
  @@index([unitId])
}
